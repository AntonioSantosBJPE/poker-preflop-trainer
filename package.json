{
  "name": "preflop-trainer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Preflop Trainer — NLHE 6-Max (Electron)",
  "homepage": "https://github.com/local/preflop-trainer",
  "author": "Preflop Trainer <preflop-trainer@example.com>",
  "main": "out/main/index.js",
  "scripts": {
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "dev": "electron-vite dev",
    "dev:gpu-safe": "electron-vite dev -- --disable-gpu",
    "build": "electron-vite build && mkdir -p out/main/db && cp -r src/main/db/migrations out/main/db/migrations && electron-builder",
    "preview": "electron-vite preview",
    "build:app": "electron-vite build && mkdir -p out/main/db && cp -r src/main/db/migrations out/main/db/migrations",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "pnpm test:unit && pnpm test:e2e:ci",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ci": "pnpm build:app && playwright test",
    "test:e2e:coverage": "pnpm build:app && playwright test --reporter=html",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "lint": "eslint .",
    "lint:tests": "pnpm lint:tests:eslint && pnpm lint:tests:types",
    "lint:tests:fix": "pnpm lint:tests:eslint --fix && pnpm lint:tests:types",
    "lint:tests:eslint": "eslint --no-error-on-unmatched-pattern \"src/**/*.test.ts\" \"src/**/*.spec.ts\" \"e2e/**/*.ts\"",
    "lint:tests:types": "tsc --noEmit -p tsconfig.e2e.json",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@fontsource/fraunces": "5.2.9",
    "@fontsource/outfit": "5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "electron-log": "^5.2.4",
    "jsonwebtoken": "^9.0.2",
    "keytar": "^7.9.0",
    "lucide-react": "^1.14.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.74.0",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.10",
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1",
    "electron-builder-squirrel-windows": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.13",
    "prettier": "^3.8.3",
    "sql.js": "^1.14.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild",
      "keytar"
    ]
  }
}
