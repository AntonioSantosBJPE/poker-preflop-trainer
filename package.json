{
  "name": "preflop-trainer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Preflop Trainer — NLHE 6-Max (Electron)",
  "homepage": "https://github.com/local/preflop-trainer",
  "author": "Preflop Trainer <preflop-trainer@example.com>",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:gpu-safe": "electron-vite dev -- --disable-gpu",
    "build": "electron-vite build && mkdir -p out/main/db && cp -r src/main/db/migrations out/main/db/migrations && electron-builder",
    "preview": "electron-vite preview",
    "build:app": "electron-vite build && mkdir -p out/main/db && cp -r src/main/db/migrations out/main/db/migrations",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ci": "pnpm build:app && playwright test",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.8.1",
    "drizzle-orm": "^0.38.4",
    "electron-log": "^5.2.4",
    "jsonwebtoken": "^9.0.2",
    "keytar": "^7.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.74.0",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.15.0",
    "zod": "^4.4.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "1.49.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.30.1",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.16.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild",
      "keytar"
    ]
  }
}
